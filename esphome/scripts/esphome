#!/usr/bin/env bash

# ESPHome wrapper script
# Runs ESPHome via uv for native serial port access

set -Eeuo pipefail

# ESPHome version
ESPHOME_VERSION="2026.3.3"

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Set the ESPHome config directory (parent of scripts directory)
ESPHOME_DIR="${ESPHOME_DIR:-$(dirname "$SCRIPT_DIR")}"

# Ensure we're in the ESPHome directory
cd "$ESPHOME_DIR" || exit 1

# Keep PlatformIO cache in the repo tree (cleaned by scripts/cleanup).
# PLATFORMIO_CORE_DIR is the current env var; PLATFORMIO_HOME_DIR is deprecated.
export PLATFORMIO_CORE_DIR="${ESPHOME_DIR}/.platformio"

# Run ESPHome via uv with pip included (required by PlatformIO)
exec uv run --with pip --with "esphome==${ESPHOME_VERSION}" esphome "$@"
