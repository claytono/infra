{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token"
    },

    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": ["https://frank-gateway.k.oneill.net"]
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "replyToMode": "all",
      "dm": {
        "enabled": true
      },
      "dmPolicy": "allowlist",
      "groupPolicy": "open",
      "requireMention": false,
      "allowFrom": ["U08060TS9"],
      "execApprovals": {
        "enabled": true,
        "approvers": ["U08060TS9"]
      }
    }
  },
  "approvals": {
    "exec": {
      "enabled": true,
      "mode": "session"
    }
  },
  "tools": {
    "exec": {
      "ask": "always"
    }
  },
  "plugins": {
    "entries": {
      "slack": {
        "enabled": true
      }
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpUrl": "http://127.0.0.1:9222",
        "color": "#FF4500"
      }
    }
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "off",
        "workspaceAccess": "rw"
      },
      "memorySearch": {
        "provider": "ollama",
        "model": "snowflake-arctic-embed2",
        "remote": {
          "baseUrl": "http://ollama.ollama.svc.cluster.local:11434"
        }
      }
    }
  }
}
