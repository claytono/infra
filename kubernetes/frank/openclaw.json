{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token"
    },

    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": ["https://frank-gateway.k.oneill.net"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "streaming": true,
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["8673299463"],
      "groups": {
        "*": {
          "requireMention": false
        }
      }
    },
    "slack": {
      "enabled": true,
      "replyToMode": "all",
      "dm": {
        "enabled": true
      },
      "dmPolicy": "allowlist",
      "groupPolicy": "open",
      "requireMention": false,
      "allowFrom": ["U08060TS9"]
    }
  },
  "tools": {
    "exec": {
      "ask": "always"
    }
  },
  "plugins": {
    "entries": {
      "slack": {
        "enabled": true
      }
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpUrl": "http://127.0.0.1:9222",
        "color": "#FF4500"
      }
    }
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "off",
        "workspaceAccess": "rw"
      }
    }
  }
}
