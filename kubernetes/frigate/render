#!/usr/bin/env bash
set -eu -o pipefail
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$BASEDIR"
source "$BASEDIR/../scripts/chart-version"

rm -rf helm tmp
mkdir -p tmp helm/frigate

helm_template frigate frigate --namespace frigate --values values.yaml --output-dir tmp
mv tmp/frigate/templates/* helm/frigate/
rm -rf tmp

# Delete Helm-managed ConfigMap — we create our own via kustomize configMapGenerator
rm -f helm/frigate/configmap.yaml

# Fix ingress for ak-tool: set numeric port (ak-tool maps "http" to 80, but
# Frigate's service uses 5000) and add namespace (ingress is in helm/
# subdirectory where ak-tool can't find kustomization.yaml)
sed -i 's/name: http$/number: 5000/' helm/frigate/ingress.yaml
sed -i '/^  name: frigate$/a\  namespace: frigate' helm/frigate/ingress.yaml
