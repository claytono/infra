#!/usr/bin/env python3
"""Render Prometheus file_sd targets from Ansible node_exporter hosts."""

import argparse
import json
import subprocess
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]
ANSIBLE_DIR = REPO_ROOT / "ansible"
OUTPUT_FILE = (
    REPO_ROOT / "kubernetes" / "prometheus" / "config" / "node-exporter-targets.yml"
)


def load_inventory() -> dict:
    result = subprocess.run(
        ["ansible-inventory", "--list"],
        cwd=ANSIBLE_DIR,
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, file=sys.stderr)
        if result.stderr:
            print(result.stderr, file=sys.stderr)
        raise SystemExit(result.returncode)

    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        print(f"Failed to parse ansible-inventory JSON: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc


def render_targets(inventory: dict) -> str:
    hostvars = inventory.get("_meta", {}).get("hostvars", {})
    targets = []

    for inventory_hostname, vars_ in sorted(hostvars.items()):
        if vars_.get("node_exporter_enabled") is not True:
            continue

        address = vars_.get("ansible_host") or inventory_hostname
        port = vars_.get("node_exporter_port") or 9100
        targets.append(f"{address}:{port}")

    if not targets:
        print("No hosts with node_exporter_enabled=true found", file=sys.stderr)
        raise SystemExit(1)

    lines = [
        "---",
        "# AUTO-GENERATED - DO NOT EDIT",
        "# Generated by: kubernetes/prometheus/render",
        "# Source: ansible resolved inventory where node_exporter_enabled is true",
    ]

    for index, target in enumerate(targets):
        if index:
            lines.append("")
        lines.extend(
            [
                "- targets:",
                f"  - {json.dumps(target)}",
            ]
        )

    lines.append("")
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Render Prometheus node_exporter file_sd targets from Ansible inventory"
    )
    parser.parse_args()

    rendered = render_targets(load_inventory())
    OUTPUT_FILE.write_text(rendered, encoding="utf-8")
    target_count = rendered.count("- targets:")
    print(f"Generated {OUTPUT_FILE.relative_to(REPO_ROOT)} with {target_count} targets")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
