#!/usr/bin/env python3
"""
Render and sync script for restic kubernetes resources.

Renders:
  - Generates forget and check cronjobs from Jinja2 template

Syncs:
  - Retrieves plaintext passwords from 1Password
  - Generates bcrypt hashes and stores in 1Password (for K8s ExternalSecrets)
  - Writes ansible-vault encrypted secrets to group_vars

Prerequisites: op (1Password CLI), ansible-vault, bcrypt, jinja2
Usage: ./render-and-sync [--cronjobs] [--secrets] [--create-missing] [--healthchecks]
       With no args, runs cronjobs and secrets.
       --create-missing allows --secrets to bootstrap absent 1Password fields.
       --healthchecks requires HEALTHCHECK_API_KEY env var.
"""

import hashlib
import json
import os
import subprocess
import sys
import urllib.request
from pathlib import Path

import bcrypt
from jinja2 import Environment, FileSystemLoader

BASEDIR = Path(__file__).parent.resolve()
REPO_ROOT = BASEDIR.parent.parent
VAULT = "infra"
OP_ITEM = "restic-rest-server"
ANSIBLE_SECRETS_FILE = REPO_ROOT / "ansible/group_vars/all/restic-repo-secrets.yaml"
ANSIBLE_VAULT_PASSWORD_FILE = REPO_ROOT / "ansible/ansible-vault-password"
TEMPLATE_REPO_VERSION = "v1"
TEMPLATE_PASSWORD_FIELD = f"template-{TEMPLATE_REPO_VERSION}-password"

# Repos to manage - adding a repo here:
# 1. Creates password in 1Password
# 2. Updates htpasswd for REST server
# 3. Generates forget and check cronjobs
# 4. Updates Ansible vault secrets
REPOS = ["main", "flux", "xtal"]

# Commands to generate cronjobs for (each gets its own job and healthcheck)
COMMANDS = ["forget", "check"]


def run(cmd: list[str], capture: bool = False, check: bool = True) -> str:
    """Run a command, optionally capturing output."""
    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        print(result.stdout, file=sys.stderr)
        print(result.stderr, file=sys.stderr)
        if check:
            raise subprocess.CalledProcessError(result.returncode, cmd)
    return result.stdout.strip() if capture else ""


def schedule_from_name(name: str, offset_hours: int = 0) -> str:
    """Generate deterministic schedule from name.

    Spreads jobs throughout the week based on hash of name.
    Runs once weekly on a calculated day/hour.
    offset_hours can be used to stagger related jobs (e.g., check after forget).
    """
    h = int(hashlib.md5(name.encode()).hexdigest()[:8], 16)
    day = h % 7  # Day of week 0-6 (Sunday-Saturday)
    hour = (6 + (h % 12) + offset_hours) % 24  # Base hours 6-17, offset wraps to 0-23
    minute = h % 60

    return f"{minute} {hour} * * {day}"


def generate_cronjobs() -> None:
    """Generate forget and check cronjobs from Jinja2 template."""
    print("Generating cronjobs...")
    env = Environment(loader=FileSystemLoader(BASEDIR))
    template = env.get_template("cronjob-nfs.yaml.j2")
    outdir = BASEDIR / "cronjobs"

    for repo in REPOS:
        for i, command in enumerate(COMMANDS):
            # Offset check by 2 hours after forget
            schedule = schedule_from_name(repo, offset_hours=i * 2)
            content = template.render(
                profile=repo,
                command=command,
                schedule=schedule,
            )
            outfile = outdir / f"cronjob-{repo}-{command}.yaml"
            outfile.write_text(content.rstrip() + "\n")
            print(f"  Generated {outfile.name} (schedule: {schedule})")


def op_item_get_cmd() -> list[str]:
    """Return the safe command used to fetch the 1Password item."""
    return ["op", "--vault", VAULT, "item", "get", OP_ITEM, "--format", "json"]


def fetch_1password_item() -> dict:
    """Fetch the full 1Password item JSON."""
    result = subprocess.run(
        op_item_get_cmd(),
        capture_output=True,
        text=True,
        check=False,
    )

    if result.returncode == 0:
        return json.loads(result.stdout)

    print(result.stdout, file=sys.stderr)
    print(result.stderr, file=sys.stderr)
    raise subprocess.CalledProcessError(
        result.returncode,
        op_item_get_cmd(),
        output=result.stdout,
        stderr=result.stderr,
    )


def ensure_1password_item(*, create_missing: bool = False) -> None:
    """Verify the 1Password item exists, optionally creating it for bootstrap."""
    try:
        fetch_1password_item()
        return
    except subprocess.CalledProcessError:
        if not create_missing:
            raise

        result = subprocess.run(
            ["op", "--vault", VAULT, "item", "list", "--format", "json"],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode != 0:
            print(result.stdout, file=sys.stderr)
            print(result.stderr, file=sys.stderr)
            raise subprocess.CalledProcessError(
                result.returncode,
                ["op", "--vault", VAULT, "item", "list", "--format", "json"],
                output=result.stdout,
                stderr=result.stderr,
            )

        matching_items = [
            item for item in json.loads(result.stdout) if item.get("title") == OP_ITEM
        ]
        if matching_items:
            raise

        print(f"Creating 1Password item: {OP_ITEM}")
        run(
            [
                "op",
                "--vault",
                VAULT,
                "item",
                "create",
                "--category",
                "password",
                "--title",
                OP_ITEM,
            ]
        )


def op_secret_ref(field: str) -> str:
    """Build a 1Password secret reference for a field label."""
    return f"op://{VAULT}/{OP_ITEM}/{field}"


def read_1password_field(field: str) -> str:
    """Read an existing 1Password field value and fail closed on errors."""
    cmd = ["op", "read", "--no-newline", op_secret_ref(field)]
    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        check=False,
    )

    if result.returncode == 0 and result.stdout:
        return result.stdout.strip()

    print(result.stdout, file=sys.stderr)
    print(result.stderr, file=sys.stderr)
    raise subprocess.CalledProcessError(
        result.returncode,
        cmd,
        output=result.stdout,
        stderr=result.stderr,
    )


def item_has_field(item: dict, field: str) -> bool:
    """Return whether the 1Password item already has a field label."""
    return any(existing.get("label") == field for existing in item.get("fields", []))


def edit_1password_item(item: dict) -> None:
    """Update the 1Password item using JSON on stdin so secrets are not in argv."""
    cmd = ["op", "--vault", VAULT, "item", "edit", OP_ITEM]
    result = subprocess.run(
        cmd,
        input=json.dumps(item),
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        print("op item edit failed; output redacted", file=sys.stderr)
        raise subprocess.CalledProcessError(
            result.returncode,
            cmd,
            output="redacted",
            stderr="redacted",
        )


def upsert_1password_field(field: str, value: str) -> None:
    """Create or update a concealed 1Password field without argv secrets."""
    item = fetch_1password_item()
    fields = item.setdefault("fields", [])
    for existing in fields:
        if existing.get("label") == field:
            existing["type"] = "CONCEALED"
            existing["value"] = value
            break
    else:
        fields.append(
            {
                "label": field,
                "type": "CONCEALED",
                "value": value,
            }
        )
    edit_1password_item(item)


def generate_password() -> str:
    """Generate a URL-safe password."""
    password = run(
        ["openssl", "rand", "-base64", "32"],
        capture=True,
    )
    return password.translate(str.maketrans("", "", "/+="))[:32]


def get_or_create_password(repo: str, *, create_missing: bool = False) -> str:
    """Get an existing password, optionally bootstrapping an absent field."""
    field = repo if repo.endswith("-password") else f"{repo}-password"

    try:
        return read_1password_field(field)
    except subprocess.CalledProcessError:
        if not create_missing:
            raise

        item = fetch_1password_item()
        if item_has_field(item, field):
            raise

    # Generate new password only when explicit bootstrap mode found no field.
    print(f"  Generating password for {field}...", file=sys.stderr)
    password = generate_password()
    upsert_1password_field(field, password)
    return password


def update_htpasswd_hash(repo: str, password: str) -> None:
    """Generate bcrypt hash and update in 1Password."""
    field = f"{repo}-htpasswd"

    # rest-server accepts $2a$/$2b$ bcrypt hashes. Some htpasswd builds emit
    # $2y$, which rest-server rejects as an invalid htpasswd entry.
    hash_value = bcrypt.hashpw(
        password.encode(),
        bcrypt.gensalt(rounds=5, prefix=b"2b"),
    ).decode()

    upsert_1password_field(field, hash_value)
    print(f"  Updated {field} in 1Password", file=sys.stderr)


def encrypt_password(password: str) -> str:
    """Encrypt password using ansible-vault."""
    result = subprocess.run(
        [
            "ansible-vault",
            "encrypt_string",
            "--vault-password-file",
            str(ANSIBLE_VAULT_PASSWORD_FILE),
            "--stdin-name",
            "tmp",
        ],
        input=password,
        capture_output=True,
        text=True,
        check=True,
    )
    # Skip the "tmp: !vault |" line
    lines = result.stdout.strip().split("\n")
    return "\n".join(lines[1:])


def sync_healthchecks() -> None:
    """Create/update healthchecks entries for each repo and command."""
    print("Syncing healthchecks...")

    api_key = os.environ.get("HEALTHCHECK_API_KEY")
    if not api_key:
        print("  HEALTHCHECK_API_KEY not set, skipping", file=sys.stderr)
        return

    for repo in REPOS:
        for i, command in enumerate(COMMANDS):
            slug = f"kube-restic-{repo}-{command}"
            schedule = schedule_from_name(repo, offset_hours=i * 2)

            data = {
                "name": slug,
                "slug": slug,
                "schedule": schedule,
                "tz": "America/New_York",
                "tags": "backup kubernetes restic",
                "grace": 86400,
                "unique": ["slug"],
            }

            req = urllib.request.Request(
                "https://hc.k.oneill.net/api/v3/checks/",
                data=json.dumps(data).encode(),
                headers={
                    "X-Api-Key": api_key,
                    "Content-Type": "application/json",
                },
                method="POST",
            )

            try:
                with urllib.request.urlopen(req) as resp:
                    resp.read()  # Ensure request completes
                    print(f"  Created/updated: {slug} (schedule: {schedule})")
            except urllib.error.HTTPError as e:
                body = e.read().decode()
                print(
                    f"  Error for {slug}: {e.code} {e.reason}: {body}", file=sys.stderr
                )


def sync_secrets(*, create_missing: bool = False) -> None:
    """Sync secrets between 1Password and Ansible vault."""
    print("Syncing restic-rest-server secrets...")

    ensure_1password_item(create_missing=create_missing)

    lines = [
        "# DO NOT EDIT - managed by kubernetes/restic/render-and-sync",
        "---",
        "restic_repo_secrets:",
    ]

    for repo in REPOS:
        print(f"  Processing repo: {repo}", file=sys.stderr)

        # Get plaintext password; normal sync fails closed if it is missing.
        password = get_or_create_password(repo, create_missing=False)

        # Update bcrypt hash in 1Password (for K8s ExternalSecrets)
        update_htpasswd_hash(repo, password)

        # Encrypt for Ansible
        encrypted = encrypt_password(password)

        lines.append(f"  {repo}:")
        lines.append(f"    username: {repo}")
        lines.append("    password: !vault |")
        lines.append(encrypted)

    print(
        f"  Processing template repo password: {TEMPLATE_PASSWORD_FIELD}",
        file=sys.stderr,
    )
    template_password = get_or_create_password(
        TEMPLATE_PASSWORD_FIELD,
        create_missing=create_missing,
    )
    template_encrypted = encrypt_password(template_password)

    lines.append("restic_template_password: !vault |")
    lines.append(template_encrypted)

    ANSIBLE_SECRETS_FILE.write_text("\n".join(lines) + "\n")

    print()
    print("Sync complete!")
    print(f"Wrote: {ANSIBLE_SECRETS_FILE}")
    print()
    print("1Password fields updated:")
    print("  - *-password: plaintext passwords")
    print("  - *-htpasswd: bcrypt hashes (for K8s)")
    print(f"  - {TEMPLATE_PASSWORD_FIELD}: plaintext template repo password")


def main() -> None:
    """Main entry point."""
    args = sys.argv[1:]

    if "-h" in args or "--help" in args:
        print(__doc__)
        sys.exit(0)

    # Default to cronjobs+secrets if no args (healthchecks requires explicit flag)
    run_cronjobs = "--cronjobs" in args or not args
    run_secrets = "--secrets" in args or not args
    run_healthchecks = "--healthchecks" in args
    create_missing = "--create-missing" in args

    if create_missing and not run_secrets:
        print("--create-missing is only valid with --secrets", file=sys.stderr)
        sys.exit(2)

    if run_cronjobs:
        generate_cronjobs()

    if run_secrets:
        sync_secrets(create_missing=create_missing)

    if run_healthchecks:
        sync_healthchecks()


if __name__ == "__main__":
    main()
