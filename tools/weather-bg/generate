def generate_image(name, api_key):
    """Generate a single weather background image."""
    prompt = PREAMBLE + IMAGES[name]

    payload = {
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {
            "responseModalities": ["image", "text"],
        },
    }

    req = urllib.request.Request(
        f"{GEMINI_URL}?key={api_key}",
        data=json.dumps(payload).encode(),
        headers={"Content-Type": "application/json"},
    )

    with urllib.request.urlopen(req, timeout=120) as resp:
        data = json.loads(resp.read())

    for candidate in data.get("candidates", []):
        for part in candidate.get("content", {}).get("parts", []):
            if "inlineData" in part:
                img_data = base64.b64decode(part["inlineData"]["data"])
                raw_path = os.path.join(IMAGE_DIR, f"{name}-raw.png")
                tmp_path = os.path.join(IMAGE_DIR, f"{name}.tmp.png")
                final_path = os.path.join(IMAGE_DIR, f"{name}.png")
                with open(raw_path, "wb") as f:
                    f.write(img_data)
                try:
                    subprocess.run(
                        ["sips", "-z", "600", "1024", raw_path, "--out", tmp_path],
                        capture_output=True,
                        check=True,
                    )
                    subprocess.run(
                        ["ect", "-9", "--allfilters", tmp_path],
                        capture_output=True,
                        check=True,
                    )
                    os.replace(tmp_path, final_path)
                    return final_path
                finally:
                    for p in [raw_path, tmp_path]:
                        if os.path.exists(p):
                            os.remove(p)

    # Check for safety/content filter blocks
    feedback = data.get("promptFeedback", {})
    block_reason = feedback.get("blockReason", "")
    candidates = data.get("candidates", [])
    finish_reason = candidates[0].get("finishReason", "") if candidates else ""
    if block_reason:
        raise RuntimeError(f"Blocked by safety filter: {block_reason}")
    if finish_reason and finish_reason != "STOP":
        raise RuntimeError(f"Generation failed: finishReason={finish_reason}")
    raise RuntimeError(f"No image returned for {name}")


def upload():
    """Upload images to server via rsync."""
    pngs = sorted(f for f in os.listdir(IMAGE_DIR) if f.endswith(".png"))
    if not pngs:
        print("No images to upload")
        sys.exit(1)

    print(f"Uploading {len(pngs)} images to {UPLOAD_DEST}")
    try:
        subprocess.run(
            [
                "rsync",
                "-avP",
                "--include=*.png",
                "--exclude=*",
                IMAGE_DIR + "/",
                UPLOAD_DEST,
            ],
            check=True,
        )
    except subprocess.CalledProcessError:
        print("Upload failed")
        sys.exit(1)


def main():
    os.makedirs(IMAGE_DIR, exist_ok=True)

    args = sys.argv[1:]

    if "--list" in args:
        for name in sorted(IMAGES):
            print(name)
        return

    if "--upload" in args:
        upload()
        return

    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        print("Error: GEMINI_API_KEY environment variable required")
        sys.exit(1)

    regen_all = "--all" in args
    specific = [a for a in args if not a.startswith("-")]

    if specific:
        # Validate names
        for name in specific:
            if name not in IMAGES:
                print(f"Error: unknown image '{name}'")
                print(f"Valid names: {', '.join(sorted(IMAGES))}")
                sys.exit(1)
        targets = specific
    elif regen_all:
        targets = list(IMAGES)
    else:
        # Only generate missing images
        targets = [
            name
            for name in IMAGES
            if not os.path.exists(os.path.join(IMAGE_DIR, f"{name}.png"))
        ]
        if not targets:
            print("All images exist. Use --all to regenerate or specify names.")
            return

    generated = 0
    errors = 0

    for name in targets:
        print(
            f"Generating {name} ({generated + 1}/{len(targets)})...",
            end=" ",
            flush=True,
        )
        try:
            path = generate_image(name, api_key)
            size = os.path.getsize(path)
            print(f"OK ({size} bytes)")
            generated += 1
        except urllib.error.HTTPError as e:
            print(f"ERROR: HTTP {e.code} - {e.reason}")
            errors += 1
            if e.code in (429, 503):
                print("  Rate limited, waiting 30s...")
                time.sleep(30)
        except urllib.error.URLError as e:
            print(f"ERROR: Network - {e.reason}")
            errors += 1
        except Exception as e:
            print(f"ERROR: {e}")
            errors += 1
        time.sleep(2)

    print(f"\nDone! Generated: {generated}, Errors: {errors}")
    if errors:
        sys.exit(1)


if __name__ == "__main__":
    main()
