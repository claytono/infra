#!/usr/bin/env python3
"""Generate weather background images and upload to server.

Requires environment variables:
  GEMINI_API_KEY - Google Gemini API key for image generation

Usage:
  generate                     # Generate all missing images
  generate --all               # Regenerate all images
  generate sunny-day rainy-day # Regenerate specific images
  generate --upload            # Upload images to luser via rsync
  generate --list              # List all image names
"""

import json
import base64
import urllib.error
import urllib.request
import subprocess
import sys
import os
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
IMAGE_DIR = os.path.join(SCRIPT_DIR, "images")
UPLOAD_DEST = "luser.oneill.net:/fs1/photos/weather-backgrounds/"

GEMINI_URL = "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-image-preview:generateContent"

PREAMBLE = (
    "Generate an image in 17:10 wide landscape aspect ratio. Photorealistic "
    "photograph. Clean uncluttered composition — no text, no people. "
    "Realistic photographic lighting similar to Apple iOS weather app "
    "backgrounds. Not illustrated, not cartoonish, not painterly. "
)

